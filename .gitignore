# Python
.venv/
__pycache__/
*.pyc

# Local data & runtime artifacts (regenerated by the tool, not redistributed)
data/catalyst.db
data/universe/*.csv
data/universe/*.json
runtime/context_pack.md
runtime/context_pack.json
runtime/logs/*.log
digests/*.md

# Dashboard / browser test artifacts (screenshots, playwright temp)
dash-*.png
.playwright-mcp/

# Keep the empty dirs tracked
!data/universe/.gitkeep
!runtime/logs/.gitkeep
!digests/.gitkeep
